# Copy to backend/.dev.vars for local dev (or set via `wrangler secret put` in prod).
# Never commit real values — this file only holds placeholders.

# Upstream transit data source (abstracted behind a data-provider interface).
# The concrete endpoint/params must never appear in source code, only here.
TRANSIT_SOURCE_BASE_URL=
TRANSIT_SOURCE_API_KEY=
# Fixed form fields the upstream endpoint expects beyond the stop id itself.
TRANSIT_SOURCE_FORM_EXTRA_JSON=

# Contact email included in the User-Agent header sent to the upstream source.
SOURCE_USER_AGENT_CONTACT=

# Admin endpoint auth (kill switch, ideas moderation).
ADMIN_TOKEN=

# Cloudflare Turnstile (optional, for /ideas anti-spam).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Nominatim geocoding — no key required, but set a contact UA per usage policy.
NOMINATIM_USER_AGENT_CONTACT=
